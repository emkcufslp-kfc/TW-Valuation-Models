# Copy this file to `.streamlit/secrets.toml` or map the same keys
# into your Streamlit Community Cloud app settings.

TVM_WORKSPACE_ROOT = "."
TVM_SHARED_DATA_ROOT = "./artifacts/shared_data"

# Optional source-root overrides.
# In the default full-deploy setup, these are already bundled under `_external/`,
# so you usually do not need to set them.
TVM_IMFS_SOURCE_ROOT = "./_external/imfs_tw_stock"
TVM_QUANT_SOURCE_ROOT = "./_external/tw_buffett_quant"
TVM_HYBRID_SOURCE_ROOT = "./_external/tw_hybrid_model"
